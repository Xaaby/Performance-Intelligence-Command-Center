# Vite loads env from the repo root (parent folder) as well — see vite.config.ts `envDir`.
#
# Vendor Analyst (Gemini): the browser calls the Nest backend, which holds the key.
# Add GOOGLE_AI_STUDIO_API_KEY to backend/.env OR the repo-root .env (see root .env.example).
# Restart backend after changing that variable.
#
# Optional Gemini model override (default: gemini-2.5-flash). ListModels shows ids your key supports.
# VITE_GEMINI_MODEL=gemini-2.5-flash-lite
VITE_GEMINI_MODEL=gemini-2.5-flash