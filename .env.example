BACKEND_PORT=3001
# Production / Railway: comma-separated browser origins, or * for any origin (demo only; no cookies/credentials).
CORS_ORIGIN=
FRONTEND_PORT=5173
NODE_ENV=development
# When running the frontend with `npm run dev` on your machine (not in Docker), point the Vite proxy at the API:
VITE_PROXY_TARGET=http://localhost:3001

# Google AI Studio key for Vendor Analyst (Gemini). Loaded by the Nest backend.
# Create a key: https://aistudio.google.com/apikey
# Either name works (backend reads both):
GOOGLE_AI_STUDIO_API_KEY=
# VITE_GOOGLE_AI_STUDIO_API_KEY=
